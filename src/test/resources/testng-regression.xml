<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Regression Suite" verbose="1" parallel="classes" thread-count="4">

    <listeners>
        <listener class-name="listeners.TestListener"/>
        <listener class-name="listeners.RetryTransformer"/>
    </listeners>

    <test name="Full Regression">
        <groups>
            <run>
                <include name="smoke"/>
                <include name="regression"/>
                <exclude name="broken"/>
            </run>
        </groups>
        <classes>
            <class name="tests.LoginTest"/>
            <class name="tests.ProductsTest"/>
            <class name="tests.LoginDataDrivenTest"/>
            <class name="tests.CartDataDrivenTest"/>
        </classes>
    </test>

</suite>